{
  "name": "@kieranhunt/crul",
  "version": "0.1.2",
  "description": "Extract browser cookies and write them as a Netscape-format cookie jar file for curl/wget",
  "keywords": [
    "browser",
    "chrome",
    "cli",
    "cookie-jar",
    "cookies",
    "curl",
    "edge",
    "firefox",
    "netscape",
    "safari",
    "wget"
  ],
  "license": "MIT",
  "author": "Kieran Hunt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KieranHunt/crul.git"
  },
  "bin": {
    "crul": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.2.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "better-sqlite3": "^12.8.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
