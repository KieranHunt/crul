{
  "name": "@kieranhunt/crul",
  "version": "0.1.1",
  "description": "Extract browser cookies and write them as a Netscape-format cookie jar file for curl/wget",
  "type": "module",
  "bin": {
    "crul": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cookies",
    "curl",
    "wget",
    "netscape",
    "cookie-jar",
    "browser",
    "chrome",
    "firefox",
    "safari",
    "edge",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KieranHunt/crul.git"
  },
  "author": "Kieran Hunt",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.2.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
